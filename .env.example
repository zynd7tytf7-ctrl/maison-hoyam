# Site URL (used for metadata, og:image, and email notifications)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/maison_hoyam"

# Abacus AI notification API
# Used by the contact form to send email notifications
ABACUSAI_API_KEY=your_abacusai_api_key_here
WEB_APP_ID=your_web_app_id_here
NOTIF_ID_CONTACT_FORM_SUBMISSION=your_notif_id_here

# NextAuth (optional — not currently used, but reserved)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
