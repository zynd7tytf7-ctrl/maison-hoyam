generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  items           Json
  customerName    String
  phone           String
  deliveryAddress String
  notes           String?
  status          String   @default("pending")
  subtotal        Float
  createdAt       DateTime @default(now())

  @@index([orderNumber])
  @@index([createdAt])
  @@index([status])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  authorName String
  rating     Int
  text       String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}
